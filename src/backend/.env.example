# ──────────────────────────────────────────────────────────────────────────────
# 百家号自动化发布系统 - 环境变量配置示例
# 复制为 .env 并填入真实值，切勿将 .env 提交到 git
# ──────────────────────────────────────────────────────────────────────────────

# ── 必填项 ────────────────────────────────────────────────────────────────────

# 管理员初始密码（首次启动时写入 system_settings 表）
ADMIN_PASSWORD=change_me_on_first_run

# JWT 签名密钥（建议 openssl rand -hex 32 生成）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Cookie 加密主密钥（AES-256-GCM，建议 openssl rand -hex 32 生成）
COOKIE_SECRET_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# PostgreSQL 连接串（asyncpg 驱动）
DATABASE_URL=postgresql+asyncpg://bjh_user:bjh_pass@postgres:5432/bjh_db

# ── 可选项（有默认值）─────────────────────────────────────────────────────────

# Redis 连接串
REDIS_URL=redis://redis:6379/0

# Celery Broker（默认从 REDIS_URL 推导）
# CELERY_BROKER_URL=redis://redis:6379/0

# Celery Result Backend（默认从 REDIS_URL 推导）
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# Worker 并发（需与 system_settings.max_concurrent_accounts 保持一致）
CELERY_WORKER_CONCURRENCY=1

# CORS 允许来源（逗号分隔，生产环境替换为实际域名）
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志格式：json（生产） / text（本地开发）
LOG_FORMAT=json

# ── 以下配置通过 API /settings 动态管理，此处仅为初始默认值参考 ──────────────
# max_concurrent_accounts=1
# daily_limit=10
# task_timeout_minutes=60
# wecom_webhook=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
