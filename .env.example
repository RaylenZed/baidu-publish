# 百家号自动化发布管理系统 - 环境变量配置
# ⚠️  此文件仅供参考，实际部署请使用 src/backend/.env.example
#     docker-compose.yml 读取的是 src/backend/.env

# ============ 必填项 ============

# 管理员密码（登录时使用）
ADMIN_PASSWORD=your_admin_password_here

# JWT 签名密钥（必填，建议 openssl rand -hex 32 生成）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Cookie 加密密钥（32位十六进制字符串，可通过 openssl rand -hex 32 生成）
COOKIE_SECRET_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# ============ 数据库 ============

# PostgreSQL 连接字符串（必须使用 asyncpg 驱动格式）
DATABASE_URL=postgresql+asyncpg://bjh_user:bjh_pass@postgres:5432/bjh_db

# ============ Redis ============

# Redis 连接地址
REDIS_URL=redis://redis:6379/0

# ============ 可选配置 ============

# AIGC 模型：ds_v3 (DeepSeek) 或 ernie (文心一言)
AIGC_MODEL=ds_v3

# 跨账号并发数（建议不超过 3）
MAX_CONCURRENT_ACCOUNTS=1

# 单账号每日执行上限
DAILY_LIMIT=3

# 任务总超时（分钟）
TASK_TIMEOUT_MINUTES=15

# 各步骤超时（秒）
GENERATE_TIMEOUT=240
POLISH_TIMEOUT=240
COVER_TIMEOUT=60
PUBLISH_TIMEOUT=60
DRAFT_TIMEOUT=60

# 企微 Webhook（可选，机器人通知地址）
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 通知级别：all / failure_only / off
NOTIFY_LEVEL=failure_only