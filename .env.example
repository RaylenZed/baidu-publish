# 百家号自动化发布管理系统 - 单一 .env 配置
# 使用方式：
#   cp .env.example .env
#   docker compose up -d --build

# ── 容器端口与前端构建变量（Compose 读取）──────────────────────────────────────

# 后端 API 对外端口（容器内固定 8000）
BACKEND_PORT=18000

# 前端页面对外端口（容器内固定 5173）
FRONTEND_PORT=15173

# 前端编译时注入的 API / WebSocket 地址
# 如果使用 DDNS 域名，请替换 localhost 为你的域名
VITE_API_BASE_URL=http://localhost:18000/api/v1
VITE_WS_BASE_URL=ws://localhost:18000

# ── 后端必填项（backend/worker/beat 读取）─────────────────────────────────────

# 管理员初始密码（仅首次启动初始化时写入数据库）
ADMIN_PASSWORD=change_me_on_first_run

# JWT 签名密钥（建议：openssl rand -hex 32）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Cookie 加密密钥（AES-256-GCM，必须为 64 位十六进制字符串）
COOKIE_SECRET_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# PostgreSQL 连接串（asyncpg）
DATABASE_URL=postgresql+asyncpg://bjh_user:bjh_pass@postgres:5432/bjh_db

# Redis 连接串
REDIS_URL=redis://redis:6379/0

# ── 可选项（有默认值）──────────────────────────────────────────────────────────

# Worker 并发（建议与系统设置 max_concurrent_accounts 保持一致）
CELERY_WORKER_CONCURRENCY=1

# CORS 允许来源（逗号分隔）
# Homelab 示例：http://192.168.31.6:15173,http://myhome.ddns.net:15173
CORS_ORIGINS=http://localhost:15173,http://localhost:5173,http://localhost:80

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志格式：json / text
LOG_FORMAT=json
